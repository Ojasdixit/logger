# Agent configuration (use config.json instead)
# This is just a reference for what can be configured

# API endpoint
API_URL=http://localhost:4000/api

# Agent authentication key (must match backend AGENT_API_KEY)
API_KEY=agent-secret-key-2026

# Employee identifier (UUID from admin dashboard)
EMPLOYEE_ID=your-employee-id-here

# Screenshot interval in milliseconds (600000 = 10 minutes)
SCREENSHOT_INTERVAL=600000

# Activity track interval in milliseconds (10000 = 10 seconds)
ACTIVITY_TRACK_INTERVAL=10000

# Idle detection threshold in milliseconds (120000 = 2 minutes)
IDLE_THRESHOLD=120000
